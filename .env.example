# সার্ভার পোর্ট
PORT=3000

# JWT সাইন করার জন্য গোপন কী — অবশ্যই একটা লম্বা, র‍্যান্ডম স্ট্রিং দিয়ে বদলে দিন
JWT_SECRET=change-this-to-a-long-random-string

# Gemini API key — এটা শুধু সার্ভারে থাকবে, ব্রাউজারে কখনো পাঠানো হবে না
GEMINI_API_KEY=
# চাইলে মডেল পাল্টাতে পারেন (যেমন gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-flash

# অ্যাডমিন ড্যাশবোর্ডের প্রথমবারের ডিফল্ট পাসকোড — লগইন করেই এটা বদলে ফেলুন
ADMIN_DEFAULT_PASSCODE=srgroup2026
